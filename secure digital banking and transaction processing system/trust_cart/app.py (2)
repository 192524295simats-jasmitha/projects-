# ---------------- HOME PAGE ----------------

@app.route("/", methods=["GET", "POST"])
def index():

    message = ""

    if request.method == "POST":

        username = request.form["username"]
        amount = int(request.form["amount"])

        conn = sqlite3.connect("bank.db")
        cursor = conn.cursor()

        # Find account
        cursor.execute(
            "SELECT acc_no FROM accounts WHERE username=?",
            (username,)
        )

        user = cursor.fetchone()

        if user:

            acc_no = user[0]

            # Insert transaction
            cursor.execute("""
            INSERT INTO transactions
            (acc_no, type, amount)
            VALUES (?, ?, ?)
            """, (acc_no, "Deposit", amount))

            # Update balance
            cursor.execute("""
            UPDATE accounts
            SET balance = balance + ?
            WHERE acc_no = ?
            """, (amount, acc_no))

            conn.commit()

            message = "Transaction Successful"

        else:
            message = "User Not Found"

        conn.close()

    return render_template("index.html", message=message)

# ---------------- ACCOUNTS PAGE ----------------

@app.route("/accounts")
def accounts():

    conn = sqlite3.connect("bank.db")
    cursor = conn.cursor()

    cursor.execute("SELECT * FROM accounts")

    data = cursor.fetchall()

    conn.close()

    return str(data)

# ---------------- TRANSACTIONS PAGE ----------------

@app.route("/transactions")
def transactions():

    conn = sqlite3.connect("bank.db")
    cursor = conn.cursor()

    cursor.execute("SELECT * FROM transactions")

    data = cursor.fetchall()

    conn.close()

    return str(data)

# ---------------- RUN APP ----------------

if __name__ == "__main__":
    app.run(debug=True)